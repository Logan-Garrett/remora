# Server
DATABASE_URL=postgres://remora:changeme@127.0.0.1/remora
REMORA_TEAM_TOKEN=changeme
REMORA_DB_PROVIDER=postgres
REMORA_BIND=0.0.0.0:7200
REMORA_WORKSPACE_DIR=/var/lib/remora/workspaces
REMORA_CLAUDE_CMD=claude
REMORA_SKIP_PERMISSIONS=true
REMORA_RUN_TIMEOUT_SECS=600
REMORA_IDLE_TIMEOUT_SECS=1800
REMORA_GLOBAL_DAILY_CAP=10000000
REMORA_BACKFILL_LIMIT=500
REMORA_MAX_SESSIONS=100

# Sandbox (optional — set to true for Docker isolation per session)
REMORA_USE_SANDBOX=false
REMORA_DOCKER_IMAGE=ubuntu:22.04
